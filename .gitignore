# SignalCraft .gitignore

# Dependencies
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
ENV/

# Build outputs
.next/
dist/
build/
*.egg-info/
backtests/

# Environment files (keep secrets safe!)
.env
.env.local
.env.db
.env.*.local

# Database files
*.db
*.sqlite
*.sqlite3
backups/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/
.opencode/
.agent_memory/
.gemini/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Docker
docker-compose.override.yml

# Testing
.coverage
htmlcov/
.pytest_cache/
.tox/

# Misc
*.tar.gz
*.zip
.cache/

# Screenshots and Generated Images
images/
*.png
screenshots/

# Internal Docs and Sensitive Data
.env.bak
.env.db.example
SignalCraft_Architecture.docx
SignalCraft_Dashboard.jsx
SignalCraft_Developer_Guide.docx
screeners_spec.md
FnO_Developer_Setup_Guide.docx
FnO_Platform_Architecture.docx
ADMIN_PANEL_README.md
POSTGRES_QUICKSTART.md
QWEN.md
AGENTS.md

# Large Data Exclusions
data/
backend/data/
frontend/public/data/
*.parquet
*.csv
*.xlsx

# Agent Scratches and Test Files
test.py
test_data.py
scratch.py
scratch.md
task.md
walkthrough.md
implementation_plan.md
progress_report.md
init_mem_test.py
test_parquet.py
test_telegram.py
backend/scripts/test_*.py
backend/scripts/*_test_data.py
backend/scripts/create_test_data.py
# Keeping data-scripts for cronjobs
!data-scripts/*.csv
!data-scripts/*.json
!data-scripts/*.sh
!data-scripts/*.py
